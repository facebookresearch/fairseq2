#!/usr/bin/env python3
"""
Simple Inference Script for Qwen 2.5 7B Instruct Model

This script demonstrates how to perform text generation using fairseq2's
Qwen 2.5 7B Instruct model loaded from the asset system.

Usage:
    # CPU mode
    python qwen_inference.py --device cpu

    # Single GPU mode
    python qwen_inference.py --device cuda:0

    # Multi-GPU mode (using gang abstraction)
    torchrun --nproc_per_node=2 qwen_inference.py --device cuda

Features:
    - Loads Qwen 2.5 7B model from fairseq2 assets
    - Loads corresponding tokenizer from fairseq2 assets
    - Uses fairseq2's TextCompleter for text generation
    - Supports CPU, single-GPU, and multi-GPU execution via gang
    - Demonstrates sampling-based text generation
"""

import argparse
from typing import Final

import torch

from fairseq2.data.tokenizers import load_tokenizer
from fairseq2.device import Device
from fairseq2.gang import Gangs, get_default_gangs
from fairseq2.generation.sampling import SamplingSequenceGenerator, TopPSampler
from fairseq2.generation.text import TextCompleter
from fairseq2.models import load_model


def main() -> None:
    parser = argparse.ArgumentParser(
        description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter
    )
    parser.add_argument(
        "--model",
        type=str,
        default="qwen25_7b_instruct",
        help="Model name from fairseq2 assets (default: qwen25_7b_instruct)",
    )
    parser.add_argument(
        "--device",
        type=str,
        default="cpu",
        help="Device: cpu, cuda, or cuda:N (default: cpu)",
    )
    parser.add_argument(
        "--max-gen-len",
        type=int,
        default=128,
        help="Maximum generation length in tokens (default: 128)",
    )
    parser.add_argument(
        "--temperature",
        type=float,
        default=0.6,
        help="Sampling temperature (default: 0.6)",
    )
    parser.add_argument(
        "--top-p",
        type=float,
        default=0.9,
        help="Top-p (nucleus) sampling parameter (default: 0.9)",
    )
    args = parser.parse_args()

    # Setup gangs for distributed execution
    # If running with torchrun, this will setup proper multi-GPU gangs
    # Otherwise, returns fake gangs for single-device execution
    gangs: Final[Gangs] = get_default_gangs()
    device: Final[Device] = Device(args.device)

    if gangs.root.rank == 0:
        print(f"Loading model '{args.model}' from fairseq2 assets...")
        print(f"Device: {device}")
        print(f"Gang size: {gangs.root.size}")
        print("-" * 60)

    # Load model from fairseq2 assets
    # The load_model function automatically downloads the checkpoint if needed
    # and loads it onto the specified device
    model = load_model(args.model, device=device, dtype=torch.bfloat16)
    gangs.root.barrier()
    model.eval()

    if gangs.root.rank == 0:
        print(f"Model loaded successfully!")
        print(f"Model type: {type(model).__name__}")
        print("-" * 60)

    # Load tokenizer from fairseq2 assets
    # The tokenizer is associated with the model and handles text encoding/decoding
    tokenizer = load_tokenizer(args.model)

    if gangs.root.rank == 0:
        print(f"Tokenizer loaded successfully!")
        print(f"Vocabulary size: {tokenizer.vocab_info.size}")
        print("-" * 60)

    # Create a Top-P (nucleus) sampler
    # This sampler selects from the smallest set of tokens whose cumulative
    # probability exceeds the threshold (top_p)
    sampler = TopPSampler(p=args.top_p)

    # Create a sampling-based sequence generator
    # This uses the model to generate sequences via sampling
    generator = SamplingSequenceGenerator(
        model=model,
        vocab_info=tokenizer.vocab_info,
        sampler=sampler,
        max_gen_len=args.max_gen_len,
        temperature=args.temperature,
        echo_prompt=True,  # Include prompt in the output
    )

    # Create a TextCompleter
    # This is fairseq2's high-level interface for text completion
    # It handles tokenization, generation, and detokenization
    text_completer = TextCompleter(
        generator=generator,
        tokenizer=tokenizer,
        skip_special_tokens=True,  # Don't include special tokens in output
    )

    if gangs.root.rank == 0:
        print("Generator setup complete!")
        print(f"Max generation length: {args.max_gen_len}")
        print(f"Temperature: {args.temperature}")
        print(f"Top-p: {args.top_p}")
        print("-" * 60)

    # Example prompts for inference
    # NOTE: For Qwen 2.5 Instruct models, you may want to use the proper
    # instruction format, but for simplicity we use plain prompts here
    prompts = [
        "The capital of France is",
        "Artificial intelligence is defined as",
        "In machine learning, a neural network",
    ]

    if gangs.root.rank == 0:
        print("\nRunning inference on example prompts...\n")

        for i, prompt in enumerate(prompts, 1):
            print(f"Prompt {i}: {prompt}")
            print("-" * 60)

            # Generate completion for the prompt
            # The TextCompleter handles encoding the prompt, running generation,
            # and decoding the output
            completed_text, generator_output = text_completer(prompt)

            print(f"Generated: {completed_text}")
            print("-" * 60)
            print()

        print("Inference complete!")
        print("\n" + "=" * 60)
        print("NOTE: To use fairseq2 datasets from assets:")
        print("  - Dataset 'openeft' is available (dataset_family: generic_instruction)")
        print("  - You can explore dataset loading via fairseq2.datasets.DatasetHub")
        print("  - See fairseq2.datasets documentation for dataset integration")
        print("=" * 60)


if __name__ == "__main__":
    main()
